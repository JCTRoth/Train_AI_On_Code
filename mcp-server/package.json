{
  "name": "context-extractor",
  "version": "1.0.0",
  "description": "Context Extractor - Extracts method trees from objects using reflection for AI context enrichment",
  "main": "index.js",
  "scripts": {
    "test": "npm run test:python && npm run test:java && npm run test:csharp && npm run test:mcp",
    "test:python": "cd packages/context-extractor-python && python3 -m pytest tests/ -v",
    "test:java": "cd packages/context-extractor-java && mvn test",
    "test:csharp": "cd CSharp/ContextExtractor.Tests && dotnet test",
    "test:mcp": "cd packages/mcp-server && npm run test",
    "build:java": "cd packages/context-extractor-java && mvn package",
    "build:csharp": "cd CSharp/ContextExtractor.Cli && dotnet build",
    "build:mcp": "cd packages/mcp-server && npm run build",
    "start:mcp": "node packages/mcp-server/dist/index.js",
    "dev:mcp": "cd packages/mcp-server && npm run dev"
  },
  "keywords": [
    "reflection",
    "context",
    "ai",
    "copilot",
    "code-completion"
  ],
  "author": "Jonas",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.1.0",
    "nx": "22.4.4",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "zod": "^4.3.6"
  }
}
